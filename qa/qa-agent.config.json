{
  "checks": [
    {
      "id": "repository-package",
      "module": "Workspace",
      "severity": "BLOCKER",
      "kind": "file",
      "path": "package.json"
    },
    {
      "id": "database-tooling",
      "module": "Banco",
      "severity": "BLOCKER",
      "kind": "file",
      "path": "scripts/db-tool.mjs"
    },
    {
      "id": "automated-test-suite",
      "module": "API",
      "severity": "BLOCKER",
      "kind": "command",
      "command": "npm",
      "args": ["test"],
      "timeoutMs": 300000
    },
    {
      "id": "project-lm-runtime-isolation",
      "module": "Compatibilidade Premium × Projeto LM",
      "severity": "HIGH",
      "kind": "command",
      "command": "npm",
      "args": ["run", "check:project-lm-runtime"],
      "timeoutMs": 180000
    },
    {
      "id": "expected-database-schema",
      "module": "Banco",
      "severity": "BLOCKER",
      "kind": "command",
      "command": "npm",
      "args": ["run", "db:expected"],
      "timeoutMs": 180000
    },
    {
      "id": "premium-home-live",
      "module": "Portal do Aluno",
      "severity": "BLOCKER",
      "kind": "http",
      "baseUrlEnv": "QA_PREMIUM_BASE_URL",
      "path": "/portal.html",
      "expectedStatus": [200, 302],
      "required": false
    },
    {
      "id": "project-lm-home-live",
      "module": "Compatibilidade Premium × Projeto LM",
      "severity": "HIGH",
      "kind": "http",
      "baseUrlEnv": "QA_PREMIUM_BASE_URL",
      "path": "/projeto-lm/",
      "expectedStatus": [200, 302],
      "required": false
    }
  ]
}
